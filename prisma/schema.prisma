// prisma/schema.prisma
// ──────────────────────────────────────────────────
// THE MANIFESTING CAPSULE — Database Schema v1.0
// Pure Text Edition, No Spotify/Media columns
// ──────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────────
// MODEL: Manifest
// Tabel utama dan satu-satunya di MVP.
// Setiap baris = satu kapsul manifestasi teks.
// ──────────────────────────────────────────────────
model Manifest {
  id             String   @id @default(uuid())
  accessKey      String   @map("access_key")
  targetName     String   @map("target_name")
  messageContent String   @map("message_content")
  authorName     String?  @map("author_name")
  resonateCount  Int      @default(0) @map("resonate_count")
  unlockAt       DateTime @map("unlock_at")
  createdAt      DateTime @default(now()) @map("created_at")
  photoUrl       String?  @map("photo_url")
  ifNotAchieved  String?  @map("if_not_achieved")
  ifAchieved     String?  @map("if_achieved")

  @@index([accessKey])
  @@map("manifests")
}

// Tambah model baru untuk profil anonim
model Profile {
  id          String   @id @default(uuid())
  accessKey   String   @unique @map("access_key")
  name        String
  birthDate   DateTime @map("birth_date")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("profiles")
}
